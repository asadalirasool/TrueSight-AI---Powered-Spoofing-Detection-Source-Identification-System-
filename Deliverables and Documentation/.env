# Environment Configuration

# Application Settings
APP_NAME=TrueSight
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/truesight
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_HOST=localhost
API_PORT=8000
API_WORKERS=4

# ML Model Paths
MODEL_DIR=/app/models
VIDEO_MODEL_PATH=/app/models/video_detector.onnx
AUDIO_MODEL_PATH=/app/models/audio_detector.onnx
MULTILINGUAL_MODEL_PATH=/app/models/multilingual_detector

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_VIDEO_STREAMS=video-streams
KAFKA_TOPIC_AUDIO_STREAMS=audio-streams
KAFKA_TOPIC_DETECTION_RESULTS=detection-results

# Blockchain Configuration
BLOCKCHAIN_NETWORK=fabric-testnet
BLOCKCHAIN_CONTRACT_ID=evidence-contract
BLOCKCHAIN_PEER_URL=grpc://localhost:7051
BLOCKCHAIN_ORDERER_URL=grpc://localhost:7050

# Storage Configuration
STORAGE_BUCKET_NAME=truesight-media
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=https://s3.amazonaws.com

# GPU Configuration
GPU_ENABLED=True
GPU_DEVICE_ID=0
MAX_BATCH_SIZE=32

# Performance Settings
MAX_CONCURRENT_STREAMS=1000
PROCESSING_TIMEOUT_SECONDS=30
CACHE_TTL_SECONDS=3600

# Compliance Settings
GDPR_ENABLED=True
HIPAA_ENABLED=True
SOC2_ENABLED=True
EVIDENCE_RETENTION_DAYS=365